#!/usr/bin/env bash
# cage — a caged GitHub Copilot session for a repo.
#   read-only repo · throwaway sandbox copy · empty home (no keys) · caps dropped
#   local model (BYOK, offline) · EGRESS LOCKED: can reach the model + approved hosts, nothing else.
# Usage: cage [repo-path]
set -euo pipefail
REPO="$(cd "${1:-.}" && pwd)"
WORK="$HOME/.cage/$(basename "$REPO")-work"; rm -rf "$WORK"; mkdir -p "$(dirname "$WORK")"; cp -r "$REPO" "$WORK"
MODEL="$(curl -s http://localhost:1234/v1/models | python3 -c 'import sys,json;print(json.load(sys.stdin)["data"][0]["id"])')"

# Wall: network. An --internal network has NO route out (enforced by routing, not a firewall).
podman network exists cage-noegress 2>/dev/null || podman network create --internal cage-noegress >/dev/null
# The allowlist = a relay that forwards ONLY the model. Add approved hosts here, nothing else gets out.
if ! podman ps --filter name=cage-modelproxy --format '{{.Names}}' | grep -q cage-modelproxy; then
  podman run -d --name cage-modelproxy --network cage-noegress --network podman \
    -v "$(dirname "$0")/relay.js":/relay.js:ro --entrypoint node copilot-cage /relay.js >/dev/null
fi

exec podman run --rm -it \
  --network cage-noegress \
  --userns=keep-id --tmpfs /home/agent --env HOME=/home/agent \
  -v "$REPO":/src:ro -v "$WORK":/work -w /work --cap-drop=ALL \
  --env COPILOT_PROVIDER_BASE_URL=http://cage-modelproxy:1234/v1 \
  --env COPILOT_PROVIDER_API_KEY=lm-studio --env COPILOT_MODEL="$MODEL" --env COPILOT_OFFLINE=true \
  --entrypoint copilot copilot-cage
